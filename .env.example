PORT=3000
# .env is intended for local npm settings and non-secret Docker Compose interpolation.
# Put Docker Compose secret values in ./secrets/*.txt instead of this file.
# Local npm mode requires PostgreSQL. Use DATABASE_URL(_FILE) or POSTGRES_*.
# Docker Compose uses the bundled PostgreSQL/pgvector service by default.
KRIS_IMAGE=exde1968/kardashev-research-intelligence-system:latest
DATABASE_URL=
DATABASE_URL_FILE=
PYTHON_BIN=python

# Optional request/worker timing diagnostics. Logs are disabled by default.
KRIS_REQUEST_TIMING_LOG=false
KRIS_WORKER_TIMING_LOG=false
KRIS_STALE_JOB_CLEANUP_ENABLED=true
KRIS_STALE_JOB_CLEANUP_INTERVAL_MS=60000
KRIS_WORKER_JOB_STALE_AFTER_SECONDS=1800
KRIS_JOB_BACKEND=queue
KRIS_OUTBOX_POLLER_ENABLED=true
KRIS_OUTBOX_POLL_INTERVAL_MS=1000
KRIS_WORKER_POLL_INTERVAL_MS=1000
KRIS_WORKER_INIT_DB_ON_START=true
KRIS_READER_FOLLOWUPS_SYNC_FALLBACK_ENABLED=true
KRIS_PG_POOL_MAX=10
KRIS_PG_IDLE_TIMEOUT_MS=30000
KRIS_PG_CONNECTION_TIMEOUT_MS=5000

# Optional update notifications. The dashboard checks GitHub tags/releases and
# shows a unified in-app notification when a newer semver version is available.
KRIS_UPDATE_CHECK_ENABLED=true
KRIS_UPDATE_REPOSITORY=exde1968/kardashev-research-intelligence-system
KRIS_UPDATE_CHECK_INTERVAL_MS=43200000
KRIS_UPDATE_CHECK_INITIAL_DELAY_MS=30000

# Panel authentication. Leave PANEL_PASSWORD empty to keep passwordless mode.
PANEL_PASSWORD=
PANEL_PASSWORD_FILE=
PANEL_SESSION_TTL_SECONDS=604800
# Optional: set a fixed random value for production or long-lived deployments.
PANEL_SESSION_SECRET=
PANEL_SESSION_SECRET_FILE=
# Optional: set true only when dashboard is served over HTTPS.
PANEL_COOKIE_SECURE=
# Optional narrow token for kris-agent project listing and experiment report ingestion.
KRIS_AGENT_TOKEN=
KRIS_AGENT_TOKEN_FILE=

# PostgreSQL defaults. Docker Compose overrides POSTGRES_HOST to its db service
# and reads the password from ./secrets/postgres_password.txt.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=research_intelligence
POSTGRES_USER=research_app
POSTGRES_PASSWORD=
POSTGRES_PASSWORD_FILE=
APP_HOST_BIND=0.0.0.0
APP_HOST_PORT=3000

# Optional Nginx HTTPS reverse proxy for Docker Compose.
# Enable with: docker compose --profile nginx up -d
# For HTTPS deployments set APP_HOST_BIND=127.0.0.1 and PANEL_COOKIE_SECURE=true.
NGINX_SERVER_NAME=localhost
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_CERT_DIR=./deploy/nginx/certs
NGINX_CERTIFICATE=/etc/nginx/certs/fullchain.pem
NGINX_CERTIFICATE_KEY=/etc/nginx/certs/privkey.pem
NGINX_CLIENT_MAX_BODY_SIZE=64m

OBSIDIAN_VAULT_PATH=
OBSIDIAN_STORAGE_BACKEND=local
# Remote Obsidian object storage modes: oss, s3, r2.
# Remote mode lists/downloads Markdown from OBSIDIAN_REMOTE_PREFIX and writes new files only under OBSIDIAN_REMOTE_OUTPUT_PREFIX.
OBSIDIAN_REMOTE_ENDPOINT_URL=
OBSIDIAN_REMOTE_REGION=
OBSIDIAN_REMOTE_BUCKET=
OBSIDIAN_REMOTE_PREFIX=
OBSIDIAN_REMOTE_ACCESS_KEY_ID=
OBSIDIAN_REMOTE_SECRET_ACCESS_KEY=
OBSIDIAN_REMOTE_SECRET_ACCESS_KEY_FILE=
OBSIDIAN_REMOTE_MIRROR_DIR=./data/obsidian_remote_vault
OBSIDIAN_REMOTE_OUTPUT_PREFIX=Research Intelligence
OBSIDIAN_REMOTE_APPEND_ONLY=true
OBSIDIAN_INCLUDE_DIRS=Research,Papers
OBSIDIAN_INCLUDE_TAGS=research,paper,direction
OBSIDIAN_PROJECT_CENTER_TAGS=

ARXIV_CATEGORIES=cs.AI,cs.CL,cs.IR
ARXIV_DAILY_LOOKBACK_DAYS=1
ARXIV_MAX_RESULTS=50
ARXIV_REQUEST_INTERVAL_SECONDS=3
ARXIV_CACHE_FULL_TEXT=true
ARXIV_PDF_DIR=./data/arxiv_pdfs
ARXIV_TEXT_DIR=./data/arxiv_text
RETRY_DAILY_MAX_RESULTS=100

RAG_SCORE_THRESHOLD=0.35
RAG_TOP_K=6
RAG_SEARCHERS=embedding_search,keyword_search,front_page_search
RAG_PREFILTER_ENABLED=true
RAG_PREFILTER_THRESHOLD=0.18
RAG_PREFILTER_TOP_K=20
RAG_PREFILTER_MIN_KEEP=30
RAG_PREFILTER_MAX_KEEP=50

SCHEDULER_ENABLED=false
RUN_DAILY_ON_STARTUP_ENABLED=false
SCHEDULER_RUN_TIME=09:00
SCHEDULER_INTERVAL_HOURS=24

LLM_PROVIDERS_JSON=[]
LLM_PROVIDERS_JSON_FILE=
LLM_CHAT_PROVIDER_ID=
LLM_CHAT_MODEL=
LLM_EMBEDDING_PROVIDER_ID=
LLM_EMBEDDING_MODEL=
EMBEDDING_CONCURRENCY=2
